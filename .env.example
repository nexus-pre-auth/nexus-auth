# NexusAuth — Environment Variables
# ===================================
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local Docker (matches docker-compose.yml)
DATABASE_URL=postgresql://nexusauth:nexusauth@localhost:5432/nexusauth

# AWS RDS (production)
# DATABASE_URL=postgresql://nexusauth:YOUR_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/nexusauth

# ---------------------------------------------------------------------------
# Redis (for scraper job queue)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# OpenAI (required for embedding stage)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Ingestion pipeline settings
# ---------------------------------------------------------------------------
# Max documents per pipeline run (leave blank for no limit)
PIPELINE_MAX_DOCS=

# Batch size for DB operations
PIPELINE_BATCH_SIZE=100

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log file path (leave blank for stdout only)
LOG_FILE=logs/pipeline.log

# ---------------------------------------------------------------------------
# CMS MCD Download URLs (override for testing with local files)
# ---------------------------------------------------------------------------
CMS_LCD_URL=https://downloads.cms.gov/medicare-coverage-database/downloads/exports/current_lcd.zip
CMS_NCD_URL=https://downloads.cms.gov/medicare-coverage-database/downloads/exports/ncd.zip
