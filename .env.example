# CodeMed AI — Environment Variables
# =====================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to source control.

# ---------------------------------------------------------------------------
# API Authentication
# ---------------------------------------------------------------------------
# Comma-separated list of valid API keys.
# Replace with long, random strings in production.
CODEMED_API_KEYS=dev-key-codemed

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# ---------------------------------------------------------------------------
# Used by ingestion pipeline and audit log.
# Schema applied via: psql $DATABASE_URL -f database/migrations/001_initial_schema.sql
DATABASE_URL=postgresql://nexusauth:nexusauth@localhost:5432/nexusauth

# AWS RDS (production)
# DATABASE_URL=postgresql://nexusauth:YOUR_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/nexusauth

# ---------------------------------------------------------------------------
# Redis (caching layer)
# ---------------------------------------------------------------------------
# Optional — API runs without Redis (graceful fallback).
# Remove or leave blank to disable caching.
REDIS_URL=redis://localhost:6379/0

# Override individual cache TTLs (seconds). Defaults shown:
# CODEMED_CACHE_TTL_LOOKUP=604800    # 7 days  — code lookups
# CODEMED_CACHE_TTL_SEARCH=3600      # 1 hour  — search queries
# CODEMED_CACHE_TTL_HCC=2592000      # 30 days — HCC crosswalk
# CODEMED_CACHE_TTL_POLICY=86400     # 1 day   — policy index

# ---------------------------------------------------------------------------
# OpenAI (semantic code search + embeddings)
# ---------------------------------------------------------------------------
# Required for semantic search mode (pgvector embeddings).
# Without this, NLQ engine uses keyword search (still fully functional).
OPENAI_API_KEY=sk-...

# OpenAI embedding model (default: text-embedding-3-small)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Ingestion pipeline settings
# ---------------------------------------------------------------------------
# Max documents per pipeline run (leave blank for no limit)
PIPELINE_MAX_DOCS=

# Batch size for DB operations
PIPELINE_BATCH_SIZE=100

# Log file path (leave blank for stdout only)
LOG_FILE=logs/pipeline.log

# ---------------------------------------------------------------------------
# CMS MCD Download URLs (override for testing with local files)
# ---------------------------------------------------------------------------
CMS_LCD_URL=https://downloads.cms.gov/medicare-coverage-database/downloads/exports/current_lcd.zip
CMS_NCD_URL=https://downloads.cms.gov/medicare-coverage-database/downloads/exports/ncd.zip

# ---------------------------------------------------------------------------
# Streamlit Demo
# ---------------------------------------------------------------------------
# URL that the Streamlit demo uses to reach the FastAPI backend.
# Change to your deployed API URL in production.
CODEMED_API_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Stripe Billing
# ---------------------------------------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret from https://dashboard.stripe.com/webhooks
# Used to verify that webhook events come from Stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Business / HIPAA BAA
# ---------------------------------------------------------------------------
# Used in BAA agreements and billing communications
BUSINESS_NAME=CodeMed AI, LLC
BUSINESS_EMAIL=legal@codemedgroup.com

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# Set to "production" to enable security hardening (blocks default API key, etc.)
CODEMED_ENV=development

# ---------------------------------------------------------------------------
# pgAdmin (Docker Compose dev only)
# ---------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@codemed.dev
PGADMIN_DEFAULT_PASSWORD=codemed_admin
