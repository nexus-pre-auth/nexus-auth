# NexusAuth — Environment Variables
# ===================================
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local Docker (matches docker-compose.yml)
DATABASE_URL=postgresql://nexusauth:nexusauth@localhost:5432/nexusauth

# AWS RDS (production)
# DATABASE_URL=postgresql://nexusauth:YOUR_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/nexusauth

# ---------------------------------------------------------------------------
# Redis (for scraper job queue)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# OpenAI (required for embedding stage)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Ingestion pipeline settings
# ---------------------------------------------------------------------------
# Max documents per pipeline run (leave blank for no limit)
PIPELINE_MAX_DOCS=

# Batch size for DB operations
PIPELINE_BATCH_SIZE=100

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log file path (leave blank for stdout only)
LOG_FILE=logs/pipeline.log

# ---------------------------------------------------------------------------
# CMS MCD Download URLs (override for testing with local files)
# ---------------------------------------------------------------------------
CMS_LCD_URL=https://downloads.cms.gov/medicare-coverage-database/downloads/exports/current_lcd.zip
CMS_NCD_URL=https://downloads.cms.gov/medicare-coverage-database/downloads/exports/ncd.zip

# ---------------------------------------------------------------------------
# WebPT OAuth Integration
# ---------------------------------------------------------------------------
# Register your app at https://developer.webpt.com to get these values.
WEBPT_CLIENT_ID=
WEBPT_CLIENT_SECRET=
WEBPT_REDIRECT_URI=https://your-domain.com/auth/webpt/callback
WEBPT_AUTH_URL=https://auth.webpt.com/oauth/authorize
WEBPT_TOKEN_URL=https://auth.webpt.com/oauth/token
WEBPT_API_BASE=https://api.webpt.com/v1
WEBPT_SCOPES=openid profile claims:read webhooks:write

# Webhook
WEBPT_WEBHOOK_CALLBACK_URL=https://your-domain.com/webhooks/webpt
# Generate with: openssl rand -hex 32
WEBPT_WEBHOOK_SECRET=

# How far back to sync historical claims (days)
WEBPT_LOOKBACK_DAYS=365

# Token encryption key (required — keep secret)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Flask
FLASK_SECRET_KEY=
FLASK_DEBUG=false
PORT=5000

# Shared secret for internal RQ worker → app communication
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=
